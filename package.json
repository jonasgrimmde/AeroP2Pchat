{
  "name": "aero-p2p-chat",
  "version": "26.1.0",
  "description": "A clean Frutiger Aero styled Electron peer-to-peer chat client.",
  "author": "Jonas Grimm",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/run-electron-vite.cjs dev",
    "test": "node --check src/main.js && node --check src/preload.js && node --check scripts/build-inno.cjs && node --check scripts/release.cjs && node --check scripts/run-electron-vite.cjs",
    "build": "node scripts/run-electron-vite.cjs build && electron-builder --win --dir",
    "setup": "npm run build && node scripts/build-inno.cjs",
    "release": "node scripts/release.cjs",
    "patch": "node scripts/release.cjs --patch",
    "release:linux": "node scripts/release.cjs --linux-only --no-bump"
  },
  "release": {
    "owner": "jonasgrimmde",
    "repo": "AeroP2Pchat",
    "latestUrl": "https://github.com/jonasgrimmde/AeroP2Pchat/releases/latest/download/latest.yml"
  },
  "build": {
    "appId": "de.jonasgrimm.aerop2pchat",
    "productName": "Aero P2P Chat",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "assets/**/*",
      "package.json"
    ],
    "artifactName": "Aero-P2P-Chat-${version}-${os}-${arch}.${ext}",
    "win": {
      "target": "dir",
      "icon": "assets/app.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/app.png",
      "category": "Network"
    },
    "asar": true
  },
  "dependencies": {
    "peerjs": "^1.5.5"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "vite": "^5.4.20"
  }
}
