{
  "name": "aero-p2p-chat",
  "version": "26.11.0",
  "description": "A clean Frutiger Aero styled Electron peer-to-peer chat client.",
  "author": "Jonas Grimm",
  "desktopName": "Aero P2P Chat",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/run-electron-vite.cjs dev",
    "dev:2": "node scripts/dev-two.cjs",
    "test": "node --check src/main/index.js && node --check src/preload/index.js && node --check scripts/build-inno.cjs && node --check scripts/build-win.cjs && node --check scripts/dev-two.cjs && node --check scripts/release.cjs && node --check scripts/run-electron-vite.cjs",
    "build": "node scripts/build-win.cjs",
    "setup": "npm run build && node scripts/build-inno.cjs",
    "release": "node scripts/release.cjs",
    "patch": "node scripts/release.cjs --patch",
    "release:linux": "node scripts/release.cjs --linux-only --no-bump"
  },
  "release": {
    "owner": "Zorblock",
    "repo": "AeroP2Pchat",
    "latestUrl": "https://github.com/Zorblock/AeroP2Pchat/releases/latest/download/latest.yml"
  },
  "build": {
    "appId": "de.jonasgrimm.aerop2pchat",
    "productName": "Aero P2P Chat",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "assets/**/*",
      "package.json"
    ],
    "artifactName": "Aero-P2P-Chat-${version}-${os}-${arch}.${ext}",
    "win": {
      "target": "dir",
      "icon": "assets/app.ico"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "icon": "assets/linux-icons",
      "category": "Network",
      "syncDesktopName": true
    },
    "asar": true
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "peerjs": "^1.5.5"
  },
  "devDependencies": {
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "vite": "^7.3.5"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true,
    "esbuild@0.28.1": true
  }
}
